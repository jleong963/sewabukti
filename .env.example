# Public Flutter Web build configuration (safe to expose in the browser).
#
# Pass these to the build with --dart-define (see README) or
# --dart-define-from-file. EVERY value here is compiled into the client and is
# inspectable by any browser user, so ONLY public values belong here.
#
# NEVER put server-side secrets in this file or a real .env:
#   VERCEL_TOKEN, SUPABASE_ACCESS_TOKEN, SUPABASE_SERVICE_ROLE_KEY,
#   TURSO_AUTH_TOKEN, GMAIL_USER, GMAIL_APP_PASSWORD
# Those live only as GitHub Actions Secrets or in the Supabase dashboard (§7.3, §8.1).

APP_ENV=development
SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_OAUTH_CLIENT_ID=
# Client keep-alive ping interval in seconds (0 disables). Keeps Supabase warm
# while the app is open; a scheduled workflow covers zero-user periods.
KEEPALIVE_INTERVAL_SECONDS=0
# Auto-logout after this many seconds of user inactivity while signed in
# (0 disables). Client-side session-hygiene control.
INACTIVE_TIMEOUT=0
